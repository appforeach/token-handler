{
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/poc",
    "ClientId": "poc-api",
    "ClientSecret": "your-client-secret-here",
    "Realm": "poc"
  },

  "ExpiringTokensRefreshWorker": {
    "PollingInterval": "00:01:00",
    "RefreshBeforeExpiration": "00:04:00"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
